# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# Temporary files generated by your text editor or operating system
# belong in git's global ignore instead:
# `$XDG_CONFIG_HOME/git/ignore` or `~/.config/git/ignore`

# Ignore bundler config.
/.bundle

# Ignore all environment files except the example template.
/.env*
!/.env.example

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore storage (uploaded files in development).
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

/public/assets

# Ignore key files for decrypting credentials and more.
/config/*.key


# Ignore built assets
/app/assets/builds/*
!/app/assets/builds/.keep

# Ignore PostgreSQL command history and local dump files
.psql_history
/db/*.dump
/db/*.sql

# DO NOT ignore db/schema.rb or db/structure.sql 
# They are required to boot your database on other machines!

# Ignore master key and credentials for security
/config/master.key
/config/credentials/*.key

# =======================================================================
# Storage, Logs, and Temporary Files
# =======================================================================
# Active Storage uploaded files
/public/assets

# =======================================================================
# Dependencies & Assets
# =======================================================================
# Node modules (if using Webpacker, Shakapacker, or Bun/Yarn)
/node_modules
/yarn-error.log

# If using Importmaps, Tailwind, or Propshaft compiled outputs
# If using Importmaps, Tailwind, or Propshaft compiled outputs
/app/assets/builds/*
!/app/assets/builds/.keep

# Bybug / Debugging history
.byebug_history

# =======================================================================
# Environment Variables (Sensitive Info)
# =======================================================================
.env
.env*.local

# =======================================================================
# IDEs, Editors, and OS Artifacts
# =======================================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride

# VS Code
/.vscode/
