<%#
  Pagy Tailwind pagination nav.
  Usage: <render "shared/pagination", pagy: @pagy>
%>
<% if pagy.pages > 1 %>
  <nav class="flex items-center justify-between px-4 py-3 sm:px-6" aria-label="<%= t('pagination.aria_label', default: 'Pagination') %>">
    <div class="flex gap-1">
      <%# Previous %>
      <% if pagy.prev %>
        <%= link_to pagy_url_for(pagy, pagy.prev),
              class: "inline-flex items-center rounded-lg border border-slate-300 px-3 py-1.5 text-sm font-medium text-slate-700 hover:bg-slate-50" do %>
          ‹ <%= t("pagination.previous", default: "Sebelumnya") %>
        <% end %>
      <% else %>
        <span class="inline-flex items-center rounded-lg border border-slate-200 px-3 py-1.5 text-sm font-medium text-slate-400 cursor-not-allowed">‹ <%= t("pagination.previous", default: "Sebelumnya") %></span>
      <% end %>

      <%# Next %>
      <% if pagy.next %>
        <%= link_to pagy_url_for(pagy, pagy.next),
              class: "inline-flex items-center rounded-lg border border-slate-300 px-3 py-1.5 text-sm font-medium text-slate-700 hover:bg-slate-50" do %>
          <%= t("pagination.next", default: "Berikutnya") %> ›
        <% end %>
      <% else %>
        <span class="inline-flex items-center rounded-lg border border-slate-200 px-3 py-1.5 text-sm font-medium text-slate-400 cursor-not-allowed"><%= t("pagination.next", default: "Berikutnya") %> ›</span>
      <% end %>
    </div>
  </nav>
<% end %>
