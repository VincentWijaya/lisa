<div class="mx-auto max-w-7xl space-y-8 px-4 py-8 sm:px-6 lg:px-8">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-3xl font-semibold text-slate-900">Laboratory Dashboard</h1>
      <p class="mt-2 text-sm text-slate-600">Monitor specimen intake, work progress, and barcode printing.</p>
    </div>
    <div class="flex gap-3">
      <%= link_to "Works", works_path, class: "rounded-lg bg-slate-900 px-4 py-2 text-sm font-medium text-white hover:bg-slate-700" %>
      <%= link_to "Specimens", specimens_path, class: "rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50" %>
    </div>
  </div>

  <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
    <% @summary_cards.each do |card| %>
      <div class="rounded-2xl p-6 shadow-sm <%= card[:tone] %>">
        <p class="text-sm font-medium opacity-80"><%= card[:title] %></p>
        <p class="mt-3 text-3xl font-semibold"><%= card[:value] %></p>
      </div>
    <% end %>
  </div>

  <div class="grid gap-6 xl:grid-cols-2">
    <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <div class="mb-4 flex items-center justify-between">
        <h2 class="text-lg font-semibold text-slate-900">Recent Works</h2>
        <%= link_to "View all", works_path, class: "text-sm font-medium text-sky-700 hover:text-sky-600" %>
      </div>
      <div class="space-y-3">
        <% @recent_works.each do |work| %>
          <%= link_to work_path(work), class: "flex items-center justify-between rounded-xl border border-slate-200 px-4 py-3 hover:border-sky-300 hover:bg-sky-50" do %>
            <div>
              <p class="text-sm font-semibold text-slate-900"><%= work.barcode_id %></p>
              <p class="text-sm text-slate-600"><%= work.specimen.patient_name %> • <%= work.test_codes_text.presence || work.examination.name %></p>
            </div>
            <span class="rounded-full px-3 py-1 text-xs font-semibold <%= work_status_classes(work.status) %>"><%= work.status.humanize %></span>
          <% end %>
        <% end %>
      </div>
    </section>

    <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <div class="mb-4 flex items-center justify-between">
        <h2 class="text-lg font-semibold text-slate-900">Recent Specimens</h2>
        <%= link_to "View all", specimens_path, class: "text-sm font-medium text-sky-700 hover:text-sky-600" %>
      </div>
      <div class="space-y-3">
        <% @recent_specimens.each do |specimen| %>
          <%= link_to specimen_path(specimen), class: "flex items-center justify-between rounded-xl border border-slate-200 px-4 py-3 hover:border-sky-300 hover:bg-sky-50" do %>
            <div>
              <p class="text-sm font-semibold text-slate-900"><%= specimen.order_number %></p>
              <p class="text-sm text-slate-600"><%= specimen.patient_name %> • <%= specimen_summary(specimen) %></p>
            </div>
            <span class="rounded-full px-3 py-1 text-xs font-semibold <%= specimen_status_classes(specimen.status) %>"><%= specimen.status.humanize %></span>
          <% end %>
        <% end %>
      </div>
    </section>
  </div>
</div>
