<div class="mx-auto max-w-7xl space-y-6 px-4 py-8 sm:px-6 lg:px-8">
  <div class="border-b border-slate-200 pb-6">
    <div class="flex items-center gap-3">
      <div class="flex h-8 w-8 items-center justify-center rounded-md bg-sky-700 text-white">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M9 3v8a3 3 0 0 0 6 0V3"/>
          <path d="M9 3h6"/>
          <path d="M6 21h12"/>
          <path d="M10 13l-1 8"/>
          <path d="M14 13l1 8"/>
        </svg>
      </div>
      <h1 class="text-[22px] font-semibold text-slate-800"><%= t("works.index.title") %></h1>
    </div>
    <p class="mt-3 text-base text-slate-800"><%= t("works.index.subtitle") %></p>
  </div>

  <%# Search + status filter row (auto-submit; matches Specimen pattern) %>
  <%= form_with url: works_path, method: :get, local: true,
        data: { turbo_frame: "works_list", controller: "auto-submit" },
        class: "flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between" do |f| %>
    <div class="relative w-full sm:max-w-xl">
      <span class="pointer-events-none absolute inset-y-0 left-3 flex items-center text-slate-400">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="7"/>
          <line x1="20" y1="20" x2="16.65" y2="16.65"/>
        </svg>
      </span>
      <%= f.text_field :q,
            value: params[:q],
            placeholder: t("works.index.search_placeholder"),
            class: "block w-full rounded-lg border border-slate-300 bg-white py-2.5 pl-10 pr-3 text-sm text-slate-900 placeholder:text-slate-400 focus:border-sky-500 focus:outline-none focus:ring-1 focus:ring-sky-500" %>
    </div>

    <div class="relative w-full sm:w-56">
      <%= f.select :status,
            options_for_select(
              [[t("works.index.filters.status_all"), ""]] + Work.statuses.keys.map { |s| [t("works.status.#{s}"), s] },
              params[:status]
            ),
            {},
            data: { auto_submit_target: "select", action: "change->auto-submit#change" },
            class: "block w-full appearance-none rounded-md border border-slate-300 bg-white py-2.5 pl-3 pr-9 text-sm text-slate-900 focus:border-sky-500 focus:outline-none focus:ring-1 focus:ring-sky-500" %>
      <span class="pointer-events-none absolute inset-y-0 right-3 flex items-center text-slate-500">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="6 9 12 15 18 9"/>
        </svg>
      </span>
    </div>
  <% end %>

  <%# Table card + pagination inside Turbo Frame so the form only refreshes this region %>
  <%= turbo_frame_tag "works_list" do %>
    <div class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-slate-200 text-sm">
          <thead class="bg-slate-100">
            <tr>
              <% %w[barcode_id patient examination status created_at actions].each do |col| %>
                <th class="px-4 py-4 text-left text-sm font-bold text-slate-900"><%= t("works.index.table.#{col}") %></th>
              <% end %>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-200">
            <% @works.each do |work| %>
              <tr>
                <td class="px-4 py-4 align-middle text-sm font-medium text-slate-900">
                  <%= link_to work.barcode_id, work_path(work), class: "hover:text-sky-700", data: { turbo_frame: "_top" } %>
                </td>
                <td class="px-4 py-4 align-middle text-sm text-slate-900">
                  <div class="font-medium text-slate-900"><%= work.specimen.patient_name %></div>
                  <div class="mt-1 flex flex-wrap items-center gap-x-2 gap-y-0.5 text-xs text-slate-500">
                    <span><%= work.specimen.patient_id %></span>
                    <span aria-hidden="true">•</span>
                    <span><%= work.specimen.medical_record_id %></span>
                  </div>
                </td>
                <td class="px-4 py-4 align-middle text-sm text-slate-900">
                  <%= work.examination.category.presence || work.examination.name %>
                </td>
                <td class="px-4 py-4 align-middle">
                  <span class="inline-flex items-center rounded-[13.5px] px-3 py-1 text-sm font-bold <%= work_status_classes(work.status) %>">
                    <%= t("works.status.#{work.status}") %>
                  </span>
                </td>
                <td class="px-4 py-4 align-middle text-sm text-slate-900">
                  <%= l(work.created_at, format: :short_with_year) %>
                </td>
                <td class="px-4 py-4 align-middle">
                  <div class="flex items-center gap-4" data-controller="barcode-scanner">
                    <%= link_to work_path(work), title: t("works.actions.view"), aria: { label: t("works.actions.view") }, data: { turbo_frame: "_top" }, class: "inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-md text-slate-600 transition hover:bg-slate-100" do %>
                      <%= image_tag "table/ic-eye.svg", alt: "", class: "h-7 w-7" %>
                    <% end %>
                    <%= link_to barcode_label_work_path(work), target: "_blank", rel: "noopener", title: t("works.actions.print_barcode"), aria: { label: t("works.actions.print_barcode") }, data: { turbo_frame: "_top" }, class: "inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-md text-slate-600 transition hover:bg-slate-100" do %>
                      <%= image_tag "table/ic-barcode.svg", alt: "", class: "h-7 w-7" %>
                    <% end %>
                    <% if work.pending? %>
                      <%= button_tag type: "button",
                            title: t("works.actions.validate"),
                            aria: { label: t("works.actions.validate") },
                            data: { action: "click->barcode-scanner#open" },
                            class: "inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-md transition hover:bg-slate-100" do %>
                        <%= image_tag "table/ic-checked.svg", alt: "", class: "h-7 w-7" %>
                      <% end %>
                      <%= render "works/scan_validation_modal", work: work %>
                    <% else %>
                      <span title="<%= t("works.actions.validate") %>" aria-label="<%= t("works.actions.validate") %>" class="inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-md opacity-40 cursor-not-allowed">
                        <%= image_tag "table/ic-check-disabled.svg", alt: "", class: "h-7 w-7" %>
                      </span>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
            <% if @works.empty? %>
              <tr>
                <td colspan="6" class="px-4 py-12 text-center text-sm text-slate-500"><%= t("works.index.empty") %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

    <%# Pageless pagination (existing component) %>
    <%= render "shared/pagination", pagy: @pagy %>
  <% end %>
</div>
