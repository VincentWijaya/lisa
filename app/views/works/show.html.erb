<div class="mx-auto max-w-5xl space-y-6 px-4 py-8 sm:px-6 lg:px-8" data-controller="barcode-scanner">

  <%# ── Header card ─────────────────────────────────────────────────────── %>
  <div class="flex flex-col gap-4 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm sm:flex-row sm:items-start sm:justify-between">
    <div>
      <p class="text-sm font-medium text-sky-700"><%= t("works.show.label") %></p>
      <h1 class="mt-2 text-3xl font-semibold text-slate-900"><%= @work.barcode_id %></h1>
      <p class="mt-2 text-sm text-slate-600"><%= work_display_name(@work) %></p>
    </div>
    <div class="flex flex-wrap gap-2">
      <%= link_to t("works.actions.print_barcode"), barcode_label_work_path(@work), class: secondary_action_button_classes, target: "_blank", rel: "noopener" %>
      <%= button_tag t("works.actions.validate"),
          type: "button",
          disabled: !@work.pending?,
          data: (@work.pending? ? { action: "click->barcode-scanner#open" } : {}),
          class: (@work.pending? ? primary_action_button_classes : "rounded-lg bg-slate-200 px-3 py-2 text-xs font-semibold text-slate-400 cursor-not-allowed") %>
      <%= button_to t("works.actions.verify"), verify_work_work_path(@work), method: :patch, disabled: !@work.validated?, class: (@work.validated? ? primary_action_button_classes("bg-emerald-600 hover:bg-emerald-500") : "rounded-lg bg-slate-200 px-3 py-2 text-xs font-semibold text-slate-400 cursor-not-allowed") %>
      <% unless @work.verified? || @work.cancelled? %>
        <%= button_to t("works.actions.cancel"), cancel_work_work_path(@work), method: :patch, class: primary_action_button_classes("bg-rose-600 hover:bg-rose-500") %>
      <% end %>
      <%= link_to t("works.show.back"), works_path, class: secondary_action_button_classes %>
    </div>
  </div>

  <%# ── AI summary card ────────────────────────────────────────────────── %>
  <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
    <h2 class="text-lg font-semibold text-slate-900"><%= t("works.show.ai_summary_section") %></h2>
    <%= form_with model: @work, url: work_path(@work), method: :patch, class: "mt-4 space-y-3" do %>
      <%= text_area_tag "work[ai_summary]",
          @work.ai_summary,
          rows: 5,
          class: "block w-full rounded-lg border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-sky-500 focus:outline-none focus:ring-1 focus:ring-sky-500",
          placeholder: t("works.show.ai_summary_placeholder") %>
      <div class="flex justify-end">
        <%= submit_tag t("works.show.ai_summary_save"),
            class: "rounded-lg bg-sky-600 px-4 py-2 text-sm font-semibold text-white hover:bg-sky-500 cursor-pointer" %>
      </div>
    <% end %>
  </section>

  <%# ── Patient + status cards ─────────────────────────────────────────── %>
  <div class="grid gap-6 lg:grid-cols-2">
    <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <h2 class="text-lg font-semibold text-slate-900"><%= t("works.show.patient_section") %></h2>
      <dl class="mt-4 space-y-3 text-sm text-slate-700">
        <div class="flex justify-between gap-4"><dt class="font-medium"><%= t("works.show.fields.patient") %></dt><dd><%= @work.specimen.patient_name %></dd></div>
        <div class="flex justify-between gap-4"><dt class="font-medium"><%= t("works.show.fields.patient_id") %></dt><dd><%= @work.specimen.patient_id %></dd></div>
        <div class="flex justify-between gap-4"><dt class="font-medium"><%= t("works.show.fields.medical_record") %></dt><dd><%= @work.specimen.medical_record_id %></dd></div>
        <div class="flex justify-between gap-4"><dt class="font-medium"><%= t("works.show.fields.lab_id") %></dt><dd><%= @work.specimen.lab_id %></dd></div>
        <div class="flex justify-between gap-4"><dt class="font-medium"><%= t("works.show.fields.department") %></dt><dd><%= @work.specimen.department %></dd></div>
        <div class="flex justify-between gap-4"><dt class="font-medium"><%= t("works.show.fields.order_number") %></dt><dd><%= @work.specimen.order_number %></dd></div>
      </dl>
    </section>

    <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <h2 class="text-lg font-semibold text-slate-900"><%= t("works.show.status_section") %></h2>
      <dl class="mt-4 space-y-3 text-sm text-slate-700">
        <div class="flex justify-between gap-4"><dt class="font-medium"><%= t("works.show.fields.status") %></dt><dd><span class="rounded-full px-3 py-1 text-xs font-semibold <%= work_status_classes(@work.status) %>"><%= t("works.status.#{@work.status}") %></span></dd></div>
        <div class="flex justify-between gap-4"><dt class="font-medium"><%= t("works.show.fields.specimen_type") %></dt><dd><%= @work.specimen_type %></dd></div>
        <div class="flex justify-between gap-4"><dt class="font-medium"><%= t("works.show.fields.result") %></dt><dd><%= work_result_value(@work) %></dd></div>
        <div class="flex justify-between gap-4"><dt class="font-medium"><%= t("works.show.fields.interpretation") %></dt><dd><%= work_interpretation_label(@work) %></dd></div>
        <div class="flex justify-between gap-4"><dt class="font-medium"><%= t("works.show.fields.verified_at") %></dt><dd><%= @work.verified_at ? l(@work.verified_at, format: :short) : "-" %></dd></div>
        <div class="flex justify-between gap-4"><dt class="font-medium"><%= t("works.show.fields.validated_at") %></dt><dd><%= @work.validated_at ? l(@work.validated_at, format: :short) : "-" %></dd></div>
      </dl>
    </section>
  </div>

  <%# ── Results section ─────────────────────────────────────────────────── %>
  <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
    <div class="mb-4 flex items-center justify-between">
      <h2 class="text-lg font-semibold text-slate-900"><%= t("works.show.results_section") %></h2>
    </div>

    <% editable_results = @work.pending? || @work.validated? %>
    
    <%= form_with url: upsert_results_work_path(@work), method: :post, scope: :examination_results, class: "block h-full space-y-4" do %>
      <div style="height: 450px !important; overflow-y: auto !important; overflow-x: auto !important;" class="border border-slate-200 rounded-xl">
        
        <table class="min-w-full w-full border-separate border-spacing-0 text-sm isolate m-0 p-0">
          <thead class="sticky top-0 z-30 bg-slate-50 style='position: sticky; top: 0;'">
            <tr>
              <% %w[reference_rule value unit interpretation reference_range source verified_at actions].each do |col| %>
                <th class="sticky top-0 z-30 bg-slate-50 border-b border-slate-200 px-4 py-3 text-left font-semibold text-slate-700" style="position: sticky; top: 0; background-color: #f8fafc !important;">
                  <%= t("works.show.results_table.#{col}") %>
                </th>
              <% end %>
            </tr>
          </thead>
          
          <tbody class="divide-y divide-slate-100 bg-white">
            <% @reference_rules.each do |reference_rule| %>
              <% result = @results_by_reference_rule[reference_rule.id] %>
              <tr class="bg-white">
                <td class="px-4 py-3 text-slate-700 bg-white">
                  <%= reference_rule.name %>
                  <%= hidden_field_tag "examination_results[results][#{reference_rule.id}][reference_rule_id]", reference_rule.id %>
                </td>
                <td class="px-4 py-3 bg-white">
                  <% if editable_results %>
                    <%= text_field_tag "examination_results[results][#{reference_rule.id}][result_value]",
                        result&.result_value,
                        class: "block w-32 rounded-lg border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-sky-500 focus:outline-none focus:ring-1 focus:ring-sky-500",
                        autocomplete: "off" %>
                  <% else %>
                    <span class="font-medium text-slate-900"><%= result&.result_value.presence || "-" %></span>
                  <% end %>
                </td>
                <td class="px-4 py-3 bg-white">
                  <% if editable_results %>
                    <%= text_field_tag "examination_results[results][#{reference_rule.id}][result_unit]",
                        result_form_unit(result, reference_rule, @work),
                        class: "block w-28 rounded-lg border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-sky-500 focus:outline-none focus:ring-1 focus:ring-sky-500",
                        autocomplete: "off" %>
                  <% else %>
                    <span class="text-slate-700"><%= result&.result_unit.presence || "-" %></span>
                  <% end %>
                </td>
                <td class="px-4 py-3 text-slate-700 bg-white"><%= result&.interpretation.present? ? result.interpretation.humanize : "-" %></td>
                <td class="px-4 py-3 text-xs text-slate-500 bg-white"><%= reference_rule_range_display(reference_rule, result&.result_unit) %></td>
                <td class="px-4 py-3 bg-white">
                  <% if editable_results %>
                    <%= select_tag "examination_results[results][#{reference_rule.id}][source]",
                        options_for_select(result_source_options, result_form_source(result)),
                        class: "block w-32 rounded-lg border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-sky-500 focus:outline-none focus:ring-1 focus:ring-sky-500" %>
                  <% else %>
                    <span class="text-slate-700"><%= result&.source.present? ? result.source.humanize : "-" %></span>
                  <% end %>
                </td>
                <td class="px-4 py-3 text-slate-700 bg-white"><%= result&.verified_at ? l(result.verified_at, format: :short) : "-" %></td>
                <td class="px-4 py-3 bg-white">
                  <% if result.present? && result.verified_at.blank? %>
                    <%= link_to t("works.result_actions.verify"),
                        verify_work_examination_result_path(@work, result),
                        data: { turbo_method: :patch },
                        class: "text-xs font-medium text-emerald-700 hover:text-emerald-500" %>
                  <% else %>
                    <span class="text-slate-400">-</span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <% if editable_results && @reference_rules.any? %>
        <div class="flex justify-end pt-2">
          <%= submit_tag t("works.show.bulk_results.submit"), class: "rounded-lg bg-sky-600 px-4 py-2 text-sm font-semibold text-white hover:bg-sky-500 cursor-pointer" %>
        </div>
      <% end %>
    <% end %>
  </section>

  <%# ── Barcode scanner modal ───────────────────────────────────────────── %>
  <%= work_scan_validation_modal(@work) %>

</div>
