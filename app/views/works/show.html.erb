<div class="mx-auto max-w-7xl space-y-6 px-4 py-8 sm:px-6 lg:px-8" data-controller="barcode-scanner">

  <div>
    <%= link_to works_path, class: "inline-flex items-center gap-2 rounded-md border border-sky-700 px-3 py-1.5 text-sm font-semibold text-sky-700 hover:bg-sky-50" do %>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="19" y1="12" x2="5" y2="12"/>
        <polyline points="12 19 5 12 12 5"/>
      </svg>
      <%= t("works.show.back") %>
    <% end %>
  </div>

  <div class="space-y-2 border-b border-slate-200 pb-6">
    <h1 class="text-[22px] font-semibold text-slate-800"><%= t("works.show.title") %></h1>
    <nav aria-label="Breadcrumb" class="flex items-center gap-2 text-sm text-slate-500">
      <%= link_to t("works.show.breadcrumb.works"), works_path, class: "hover:text-sky-700" %>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="9 18 15 12 9 6"/>
      </svg>
      <span class="font-semibold text-sky-700"><%= t("works.show.breadcrumb.current") %></span>
    </nav>
  </div>

  <section class="rounded-2xl border border-slate-200 bg-sky-50 p-6 shadow-sm">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
      <div class="flex items-start gap-3">
        <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-md bg-sky-700 text-white">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="4" width="18" height="18" rx="2"/>
            <line x1="3" y1="10" x2="21" y2="10"/>
            <line x1="8" y1="2" x2="8" y2="6"/>
            <line x1="16" y1="2" x2="16" y2="6"/>
          </svg>
        </div>
        <div>
          <h2 class="text-[22px] font-semibold text-slate-900 leading-9"><%= @work.barcode_id %></h2>
          <p class="mt-1 text-sm text-slate-700">
            <span class="mr-1">•</span><%= @work.examination.category.presence || @work.examination.name %>
            <% if @work.test_codes_text.present? && @work.examination.name.present? %>
              <span class="ml-1">• <%= @work.examination.name %></span>
            <% end %>
          </p>
        </div>
      </div>
      <div class="flex flex-wrap items-center gap-2">
        <%= link_to barcode_label_work_path(@work), target: "_blank", rel: "noopener", class: "inline-flex items-center gap-2 rounded-md border border-sky-700 bg-white px-4 py-2 text-sm font-semibold text-sky-700 hover:bg-sky-50" do %>
          <%= t("works.actions.print_barcode") %>
        <% end %>
        <% if @work.pending? %>
          <%= button_tag type: "button",
                title: t("works.actions.validate"),
                aria: { label: t("works.actions.validate") },
                data: { action: "click->barcode-scanner#open" },
                class: "inline-flex items-center gap-2 rounded-md bg-emerald-600 px-4 py-2 text-sm font-semibold text-white hover:bg-emerald-500" do %>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            <%= t("works.actions.validate") %>
          <% end %>
        <% else %>
          <span title="<%= t("works.actions.validate") %>" aria-label="<%= t("works.actions.validate") %>" class="inline-flex items-center gap-2 rounded-md bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-400 cursor-not-allowed">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            <%= t("works.actions.validate") %>
          </span>
        <% end %>
        <% has_unverified_results = @work.examination_results.any? { |r| r.verified_at.blank? } %>
        <% if has_unverified_results %>
          <%= button_to verify_all_results_work_path(@work),
                method: :patch,
                form: { data: { turbo_confirm: t("works.show.confirm_verify_all") } },
                class: "inline-flex items-center gap-2 rounded-md bg-emerald-600 px-4 py-2 text-sm font-semibold text-white hover:bg-sky-600 cursor-pointer" do %>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="9 11 12 14 22 4"/>
              <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>
            </svg>
            <%= t("works.actions.verify") %>
          <% end %>
        <% else %>
          <span title="<%= t("works.actions.verify") %>" aria-label="<%= t("works.actions.verify") %>" class="inline-flex items-center gap-2 rounded-md bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-400 cursor-not-allowed">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="9 11 12 14 22 4"/>
              <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>
            </svg>
            <%= t("works.actions.verify") %>
          </span>
        <% end %>
      </div>
    </div>
  </section>

  <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
    <div class="flex items-start justify-between gap-4">
      <h2 class="border-b-2 border-sky-700 pb-3 text-lg font-semibold text-slate-900"><%= t("works.show.ai_summary_section") %></h2>
      <% ai_locked = @work.validated? || @work.verified? %>
      <div class="flex items-center gap-2">
        <%= button_to t("works.show.ai_summary_generate"), generate_ai_summary_work_path(@work), method: :post, disabled: ai_locked, class: "rounded-md bg-sky-700 px-4 py-2 text-sm font-semibold text-white hover:bg-sky-600 cursor-pointer disabled:cursor-not-allowed disabled:bg-slate-300 disabled:hover:bg-slate-300", data: { turbo_confirm: "Generate ringkasan AI sekarang?" } %>
        <% reset_class = ai_locked ? "rounded-md border border-slate-300 bg-slate-100 px-4 py-2 text-sm font-semibold text-slate-400 cursor-not-allowed" : "rounded-md border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50 cursor-pointer" %>
        <%= link_to t("works.show.ai_summary_reset"), ai_locked ? "#" : work_path(@work), class: reset_class, aria: { disabled: ai_locked } %>
      </div>
    </div>
    <%= form_with model: @work, url: work_path(@work), method: :patch, class: "mt-4 space-y-3" do %>
      <%= text_area_tag "work[ai_summary]",
          @work.ai_summary,
          rows: 4,
          disabled: !@work.pending?,
          class: "block w-full rounded-lg border border-slate-300 px-3 py-2 text-sm text-slate-900 placeholder:text-slate-400 shadow-sm focus:border-sky-500 focus:outline-none focus:ring-1 focus:ring-sky-500 disabled:cursor-not-allowed disabled:bg-slate-50 disabled:text-slate-500",
          placeholder: t("works.show.ai_summary_placeholder") %>
      <div class="flex justify-end">
        <%= submit_tag t("works.show.ai_summary_save"),
            disabled: !@work.pending?,
            class: "rounded-md bg-sky-700 px-4 py-2 text-sm font-semibold text-white hover:bg-sky-600 cursor-pointer disabled:cursor-not-allowed disabled:bg-slate-300 disabled:hover:bg-slate-300" %>
      </div>
    <% end %>
  </section>

  <div class="grid gap-6 lg:grid-cols-2">
    <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <h2 class="border-b-2 border-sky-700 pb-3 text-lg font-semibold text-slate-900"><%= t("works.show.patient_section") %></h2>
      <dl class="mt-4 space-y-3 text-sm text-slate-700">
        <div class="flex items-center justify-between gap-4"><dt class="font-medium text-slate-900"><%= t("works.show.fields.patient") %></dt><dd class="text-slate-900"><%= @work.specimen.patient_name %></dd></div>
        <div class="flex items-center justify-between gap-4"><dt class="font-medium text-slate-900"><%= t("works.show.fields.patient_id") %></dt><dd class="text-slate-900"><%= @work.specimen.patient_id %></dd></div>
        <div class="flex items-center justify-between gap-4"><dt class="font-medium text-slate-900"><%= t("works.show.fields.medical_record") %></dt><dd class="text-slate-900"><%= @work.specimen.medical_record_id %></dd></div>
        <div class="flex items-center justify-between gap-4"><dt class="font-medium text-slate-900"><%= t("works.show.fields.lab_id") %></dt><dd class="text-slate-900"><%= @work.specimen.lab_id %></dd></div>
        <div class="flex items-center justify-between gap-4"><dt class="font-medium text-slate-900"><%= t("works.show.fields.department") %></dt><dd class="text-slate-900"><%= @work.specimen.department %></dd></div>
        <div class="flex items-center justify-between gap-4"><dt class="font-medium text-slate-900"><%= t("works.show.fields.order_number") %></dt><dd class="text-slate-900"><%= @work.specimen.order_number %></dd></div>
      </dl>
    </section>

    <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <h2 class="border-b-2 border-sky-700 pb-3 text-lg font-semibold text-slate-900"><%= t("works.show.status_section") %></h2>
      <dl class="mt-4 space-y-3 text-sm text-slate-700">
        <div class="flex items-center justify-between gap-4"><dt class="font-medium text-slate-900"><%= t("works.show.fields.status") %></dt><dd><span class="inline-flex items-center rounded-[13.5px] px-3 py-1 text-sm font-bold <%= work_status_classes(@work.status) %>"><%= t("works.status.#{@work.status}") %></span></dd></div>
        <div class="flex items-center justify-between gap-4"><dt class="font-medium text-slate-900"><%= t("works.show.fields.specimen_type") %></dt><dd class="text-slate-900"><%= @work.specimen_type %></dd></div>
        <div class="flex items-center justify-between gap-4"><dt class="font-medium text-slate-900"><%= t("works.show.fields.result") %></dt><dd class="text-slate-900"><%= work_result_value(@work) %></dd></div>
        <div class="flex items-center justify-between gap-4"><dt class="font-medium text-slate-900"><%= t("works.show.fields.interpretation") %></dt><dd class="text-slate-900"><%= work_interpretation_label(@work) %></dd></div>
        <div class="flex items-center justify-between gap-4"><dt class="font-medium text-slate-900"><%= t("works.show.fields.verified_at") %></dt><dd class="text-slate-900"><%= @work.verified_at ? l(@work.verified_at, format: :short_with_year) : "-" %></dd></div>
        <div class="flex items-center justify-between gap-4"><dt class="font-medium text-slate-900"><%= t("works.show.fields.validated_at") %></dt><dd class="text-slate-900"><%= @work.validated_at ? l(@work.validated_at, format: :short_with_year) : "-" %></dd></div>
      </dl>
    </section>
  </div>

  <section class="space-y-4">
    <h2 class="text-lg font-semibold text-slate-900"><%= t("works.show.results_section") %></h2>

    <% editable_results = @work.pending? %>

    <%= form_with url: upsert_results_work_path(@work), method: :post, scope: :examination_results, class: "block h-full" do %>
      <div class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
        <div class="max-h-[28rem] overflow-x-auto overflow-y-auto">
          <table class="min-w-full divide-y divide-slate-200 text-sm">
            <thead class="sticky top-0 z-10 bg-slate-100 shadow-[inset_0_-1px_0_#e2e8f0]">
              <tr>
                <% %w[reference_rule value unit interpretation reference_range source verified_at].each do |col| %>
                  <th class="px-4 py-4 text-left text-sm font-bold text-slate-900"><%= t("works.show.results_table.#{col}") %></th>
                <% end %>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-200 bg-white">
              <% @reference_rules.each do |reference_rule| %>
                <% result = @results_by_reference_rule[reference_rule.id] %>
                <tr class="bg-white">
                  <td class="px-4 py-3 align-middle text-slate-900">
                    <%= reference_rule.name %>
                    <%= hidden_field_tag "examination_results[results][#{reference_rule.id}][reference_rule_id]", reference_rule.id %>
                  </td>
                  <td class="px-4 py-3 align-middle">
                    <% if editable_results %>
                      <%= text_field_tag "examination_results[results][#{reference_rule.id}][result_value]",
                          result&.result_value,
                          class: "block w-32 rounded-lg border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-sky-500 focus:outline-none focus:ring-1 focus:ring-sky-500",
                          autocomplete: "off" %>
                    <% else %>
                      <span class="font-medium text-slate-900"><%= result&.result_value.presence || "-" %></span>
                    <% end %>
                  </td>
                  <td class="px-4 py-3 align-middle">
                    <% if editable_results %>
                      <%= text_field_tag "examination_results[results][#{reference_rule.id}][result_unit]",
                          result_form_unit(result, reference_rule, @work),
                          class: "block w-28 rounded-lg border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-sky-500 focus:outline-none focus:ring-1 focus:ring-sky-500",
                          autocomplete: "off" %>
                    <% else %>
                      <span class="text-slate-700"><%= result&.result_unit.presence || "-" %></span>
                    <% end %>
                  </td>
                  <td class="px-4 py-3 align-middle text-slate-700"><%= result&.interpretation.present? ? result.interpretation.humanize : "-" %></td>
                  <td class="px-4 py-3 align-middle text-xs text-slate-500"><%= reference_rule_range_display(reference_rule, result&.result_unit) %></td>
                  <td class="px-4 py-3 align-middle">
                    <% if editable_results %>
                      <%= select_tag "examination_results[results][#{reference_rule.id}][source]",
                          options_for_select(result_source_options, result_form_source(result)),
                          class: "block w-32 rounded-lg border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-sky-500 focus:outline-none focus:ring-1 focus:ring-sky-500" %>
                    <% else %>
                      <span class="text-slate-700"><%= result&.source.present? ? result.source.humanize : "-" %></span>
                    <% end %>
                  </td>
                  <td class="px-4 py-3 align-middle text-slate-700"><%= result&.verified_at ? l(result.verified_at, format: :short_with_year) : "-" %></td>
                </tr>
              <% end %>
              <% if @reference_rules.empty? %>
                <tr>
                  <td colspan="7" class="px-4 py-12 text-center text-sm text-slate-500"><%= t("works.show.results_empty") %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>

      <% if editable_results && @reference_rules.any? %>
        <div class="flex justify-end pt-4">
          <%= submit_tag t("works.show.bulk_results.submit"), class: "rounded-md bg-sky-700 px-4 py-2 text-sm font-semibold text-white hover:bg-sky-600 cursor-pointer" %>
        </div>
      <% end %>
    <% end %>
  </section>

  <%= work_scan_validation_modal(@work) %>

</div>
