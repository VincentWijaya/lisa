<div data-barcode-scanner-target="modal"
     class="hidden fixed inset-0 z-50 flex items-center justify-center bg-slate-900/70 p-4">
  <div class="w-full max-w-md rounded-2xl bg-white shadow-xl">
    <div class="px-6 pt-6 pb-2">
      <h2 class="text-lg font-semibold text-slate-900"><%= t("works.scan_modal.title") %></h2>
      <p class="mt-2 text-sm text-slate-600"><%= t("works.scan_modal.instruction") %></p>
    </div>
    <div class="px-6 pb-6 space-y-4">
      <div class="relative overflow-hidden rounded-xl bg-slate-900 aspect-video">
        <video data-barcode-scanner-target="video"
               class="w-full h-full object-cover"
               playsinline muted autoplay></video>
        <div class="pointer-events-none absolute inset-0 flex items-center justify-center">
          <div class="rounded-xl bg-slate-900/40 px-4 py-2 text-xs font-medium text-white" data-barcode-scanner-target="status">
            <%= t("works.scan_modal.camera_hint") %>
          </div>
        </div>
      </div>

      <%= form_with url: scan_validate_work_path(work), method: :post, data: { "barcode-scanner-target": "scanForm", turbo_frame: "_top" } do |f| %>
        <div>
          <%= f.label :barcode_id, t("works.scan_modal.manual_label"), class: "block text-xs font-medium text-slate-700 mb-1" %>
          <%= f.text_field :barcode_id, data: { "barcode-scanner-target": "input" },
              class: "block w-full rounded-lg border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-sky-500 focus:outline-none focus:ring-1 focus:ring-sky-500",
              placeholder: work.barcode_id, autocomplete: "off" %>
        </div>
        <div class="mt-4 flex justify-end gap-3">
          <button type="button" data-action="click->barcode-scanner#close"
                  class="inline-flex items-center gap-2 rounded-md bg-rose-600 px-4 py-2 text-sm font-semibold text-white hover:bg-rose-500">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="18" y1="6" x2="6" y2="18"/>
              <line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
            <%= t("works.scan_modal.cancel") %>
          </button>
          <button type="button" data-action="click->barcode-scanner#submitManual"
                  class="inline-flex items-center gap-2 rounded-md bg-emerald-600 px-4 py-2 text-sm font-semibold text-white hover:bg-emerald-500">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            <%= t("works.scan_modal.submit") %>
          </button>
        </div>
      <% end %>
    </div>
  </div>
</div>
