<div class="mx-auto max-w-7xl space-y-6 px-4 py-8 sm:px-6 lg:px-8">
  <div class="border-b border-slate-200 pb-6">
    <div class="flex items-center gap-3">
      <div class="flex h-8 w-8 items-center justify-center rounded-md bg-sky-700 text-white">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M9 3v8a3 3 0 0 0 6 0V3"/>
          <path d="M9 3h6"/>
          <path d="M6 21h12"/>
          <path d="M10 13l-1 8"/>
          <path d="M14 13l1 8"/>
        </svg>
      </div>
      <h1 class="text-[22px] font-semibold text-slate-800"><%= t("specimens.index.title") %></h1>
    </div>
    <p class="mt-3 text-base text-slate-800"><%= t("specimens.index.subtitle") %></p>
  </div>

  <%# Search + status filter row (matches Figma) %>
  <%= form_with url: specimens_path, method: :get, local: true,
        data: { turbo_frame: "specimens_list", controller: "auto-submit" },
        class: "flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between" do |f| %>
    
    <%# Search Bar %>
    <div class="relative w-full sm:max-w-xl">
      <span class="pointer-events-none absolute inset-y-0 left-3 flex items-center text-slate-400">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="7"/>
          <line x1="20" y1="20" x2="16.65" y2="16.65"/>
        </svg>
      </span>
      <%= f.text_field :q,
            value: params[:q],
            placeholder: t("specimens.index.search_placeholder"),
            class: "block w-full rounded-lg border border-slate-300 bg-white py-2.5 pl-10 pr-3 text-sm text-slate-900 placeholder:text-slate-400 focus:border-sky-500 focus:outline-none focus:ring-1 focus:ring-sky-500" %>
    </div>

    <%# Grouped Filters and Buttons (Pulls them together on desktop) %>
    <div class="flex flex-col gap-3 w-full sm:w-auto sm:flex-row sm:items-center sm:gap-4">
      
      <%# Manual Input Button %>
      <div class="relative w-full sm:w-auto">
        <%= link_to t("specimens.index.manual_input"), new_specimen_path,
            class: "inline-flex items-center gap-2 rounded-lg bg-sky-700 px-4 py-2.5 text-sm font-semibold text-white hover:bg-sky-500 whitespace-nowrap" %>
      </div>

      <%# Status Filter Dropdown %>
      <div class="relative w-full sm:w-56">
        <%= f.select :status,
              options_for_select(
                [[t("specimens.index.filters.status_all"), ""]] + Specimen.statuses.keys.map { |s| [t("specimens.status.#{s}"), s] },
                params[:status]
              ),
              {},
              data: { auto_submit_target: "select", action: "change->auto-submit#change" },
              class: "block w-full appearance-none rounded-md border border-slate-300 bg-white py-2.5 pl-3 pr-9 text-sm text-slate-900 focus:border-sky-500 focus:outline-none focus:ring-1 focus:ring-sky-500" %>
        <span class="pointer-events-none absolute inset-y-0 right-3 flex items-center text-slate-500">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="6 9 12 15 18 9"/>
          </svg>
        </span>
      </div>
    </div>
  <% end %>

  <%# Table card + pagination inside Turbo Frame so the form only refreshes this region %>
  <%= turbo_frame_tag "specimens_list" do %>
    <div class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-slate-200 text-sm">
          <thead class="bg-slate-100">
            <tr>
              <% %w[order_number patient lab_id status collected_at works actions].each do |col| %>
                <th class="px-4 py-4 text-left text-sm font-bold text-slate-900"><%= t("specimens.index.table.#{col}") %></th>
              <% end %>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-200">
            <% @specimens.each do |specimen| %>
              <tr>
                <td class="px-4 py-4 align-middle text-sm font-medium text-slate-900">
                  <%= link_to specimen.order_number, specimen_path(specimen), class: "hover:text-sky-700", data: { turbo_frame: "_top" } %>
                </td>
                <td class="px-4 py-4 align-middle text-sm text-slate-900">
                  <%= specimen.patient_name %>
                </td>
                <td class="px-4 py-4 align-middle text-sm text-slate-900">
                  <%= specimen.medical_record_id %>
                </td>
                <td class="px-4 py-4 align-middle">
                  <span class="inline-flex items-center rounded-[13.5px] px-3 py-1 text-sm font-bold <%= specimen_status_classes(specimen.status) %>">
                    <%= t("specimens.status.#{specimen.status}") %>
                  </span>
                </td>
                <td class="px-4 py-4 align-middle text-sm text-slate-900">
                  <%= specimen.collection_datetime ? l(specimen.collection_datetime, format: :short_with_year) : "-" %>
                </td>
                <td class="px-4 py-4 align-middle text-sm text-slate-900">
                  <%= specimen_work_list(specimen) %>
                </td>
                <td class="px-4 py-4 align-middle">
                  <div class="flex items-center gap-4">
                    <%= link_to specimen_path(specimen), title: t("specimens.actions.view"), aria: { label: t("specimens.actions.view") }, data: { turbo_frame: "_top" }, class: "inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-md text-slate-600 transition hover:bg-slate-100" do %>
                      <%= image_tag "table/ic-eye.svg", alt: "", class: "h-7 w-7" %>
                    <% end %>
                    <%= link_to barcode_labels_specimen_path(specimen), target: "_blank", rel: "noopener", title: t("specimens.actions.print_labels"), aria: { label: t("specimens.actions.print_labels") }, data: { turbo_frame: "_top" }, class: "inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-md text-slate-600 transition hover:bg-slate-100" do %>
                      <%= image_tag "table/ic-barcode.svg", alt: "", class: "h-7 w-7" %>
                    <% end %>
                    <%= link_to send_report_form_specimen_path(specimen), title: t("specimens.actions.send_report"), aria: { label: t("specimens.actions.send_report") }, data: { turbo_frame: "send-report-modal" }, class: "inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-md text-slate-600 transition hover:bg-slate-100" do %>
                      <%= image_tag "table/ic-email.svg", alt: "", class: "h-7 w-7" %>
                    <% end %>
                    <%= link_to send_whatsapp_specimen_path(specimen), title: t("specimens.actions.send_whatsapp"), aria: { label: t("specimens.actions.send_whatsapp") }, data: { turbo_frame: "_top" }, class: "inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-md bg-[#cefde3] text-[#2f6740] transition hover:bg-[#b8f5cd]" do %>
                      <%= image_tag "table/ic-wa.svg", alt: "", class: "h-7 w-7" %>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
            <% if @specimens.empty? %>
              <tr>
                <td colspan="7" class="px-4 py-12 text-center text-sm text-slate-500"><%= t("specimens.index.empty") %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

    <%# Pagination (use existing pageless pagination) %>
    <%= render "shared/pagination", pagy: @pagy %>
  <% end %>
</div>

<%= turbo_frame_tag "send-report-modal" %>
