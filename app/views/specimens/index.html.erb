<div class="mx-auto max-w-7xl space-y-6 px-4 py-8 sm:px-6 lg:px-8">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <h1 class="text-3xl font-semibold text-slate-900"><%= t("specimens.index.title") %></h1>
      <p class="mt-2 text-sm text-slate-600"><%= t("specimens.index.subtitle") %></p>
    </div>
    <div class="flex flex-wrap items-center gap-2">
      <%= link_to t("specimens.index.manual_input"), new_specimen_path,
          class: "inline-flex items-center gap-2 rounded-lg bg-sky-600 px-4 py-2 text-sm font-semibold text-white hover:bg-sky-500" %>
      <%= link_to t("specimens.index.back"), root_path, class: "rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50" %>
    </div>
  </div>

  <%# Filters %>
  <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
    <%= form_with url: specimens_path, method: :get, class: "grid gap-3 sm:grid-cols-2 lg:grid-cols-5" do |f| %>
      <div>
        <%= f.label :status, t("specimens.index.filters.status"), class: "block text-xs font-medium text-slate-700 mb-1" %>
        <%= f.select :status,
            options_for_select(
              Specimen.statuses.keys.map { |s| [t("specimens.status.#{s}"), s] },
              params[:status]
            ),
            { include_blank: t("specimens.index.filters.status_all") },
            class: "block w-full rounded-lg border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-sky-500 focus:outline-none focus:ring-1 focus:ring-sky-500" %>
      </div>
      <div>
        <%= f.label :patient_name, t("specimens.index.filters.patient_name"), class: "block text-xs font-medium text-slate-700 mb-1" %>
        <%= f.text_field :patient_name, value: params[:patient_name],
            placeholder: t("specimens.index.filters.patient_name_placeholder"),
            class: "block w-full rounded-lg border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-sky-500 focus:outline-none focus:ring-1 focus:ring-sky-500" %>
      </div>
      <div>
        <%= f.label :medical_record_id, t("specimens.index.filters.medical_record_id"), class: "block text-xs font-medium text-slate-700 mb-1" %>
        <%= f.text_field :medical_record_id, value: params[:medical_record_id],
            placeholder: t("specimens.index.filters.medical_record_id_placeholder"),
            class: "block w-full rounded-lg border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-sky-500 focus:outline-none focus:ring-1 focus:ring-sky-500" %>
      </div>
      <div>
        <%= f.label :order_number, t("specimens.index.filters.order_number"), class: "block text-xs font-medium text-slate-700 mb-1" %>
        <%= f.text_field :order_number, value: params[:order_number],
            placeholder: t("specimens.index.filters.order_number_placeholder"),
            class: "block w-full rounded-lg border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-sky-500 focus:outline-none focus:ring-1 focus:ring-sky-500" %>
      </div>
      <div class="flex items-end gap-2">
        <%= f.submit t("specimens.index.filters.apply"),
            class: "flex-1 rounded-lg bg-slate-900 px-3 py-2 text-sm font-semibold text-white hover:bg-slate-700 cursor-pointer" %>
        <%= link_to t("specimens.index.filters.reset"), specimens_path,
            class: "rounded-lg border border-slate-300 px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50" %>
      </div>
    <% end %>
  </div>

  <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-slate-200 text-sm">
        <thead class="bg-slate-50">
          <tr>
            <% %w[order_number patient lab_id status collected_at works actions].each do |col| %>
              <th class="px-4 py-3 text-left font-semibold text-slate-700"><%= t("specimens.index.table.#{col}") %></th>
            <% end %>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% @specimens.each do |specimen| %>
            <tr>
              <td class="px-4 py-4 font-medium text-slate-900"><%= link_to specimen.order_number, specimen_path(specimen), class: "hover:text-sky-700" %></td>
              <td class="px-4 py-4 text-slate-700">
                <div class="font-medium text-slate-900"><%= specimen.patient_name %></div>
                <div class="text-xs text-slate-500"><%= specimen_summary(specimen) %></div>
              </td>
              <td class="px-4 py-4 text-slate-700"><%= specimen.lab_id %></td>
              <td class="px-4 py-4"><span class="rounded-full px-3 py-1 text-xs font-semibold <%= specimen_status_classes(specimen.status) %>"><%= t("specimens.status.#{specimen.status}") %></span></td>
              <td class="px-4 py-4 text-slate-500"><%= specimen.collection_datetime ? l(specimen.collection_datetime, format: :short) : "-" %></td>
              <td class="px-4 py-4 text-slate-700"><%= specimen.works.size %></td>
              <td class="px-4 py-4">
                <div class="flex items-center gap-2">
                  <%= action_icon_link(t("specimens.actions.view"), specimen_path(specimen), icon: :eye) %>
                  <%= action_icon_link(t("specimens.actions.print_labels"), barcode_labels_specimen_path(specimen), icon: :barcode, target: "_blank", rel: "noopener") %>
                  <%= action_icon_link(t("specimens.actions.send_report"), send_report_form_specimen_path(specimen), icon: :email, data: { turbo_frame: "send-report-modal" }) %>
                </div>
              </td>
            </tr>
          <% end %>
          <% if @specimens.empty? %>
            <tr>
              <td colspan="7" class="px-4 py-10 text-center text-sm text-slate-500"><%= t("specimens.index.empty") %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
      <%= render "shared/pagination", pagy: @pagy %>
    </div>
  </div>
</div>

<%= turbo_frame_tag "send-report-modal" %>
