<%= turbo_frame_tag "send-report-modal" do %>
  <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/40" data-action="click->turbo-frame#close">
    <div class="w-full max-w-md rounded-2xl border border-slate-200 bg-white p-6 shadow-xl" data-action="click->turbo-frame#stop">
      <h2 class="mb-1 text-lg font-semibold text-slate-900">Kirim Laporan via Email</h2>
      <p class="mb-4 text-sm text-slate-500">Spesimen: <%= @specimen.order_number %> – <%= @specimen.patient_name %></p>

      <%= form_with url: send_report_specimen_path(@specimen), method: :post, local: true, class: "space-y-4" do |f| %>
        <div>
          <%= f.label :email, "Alamat Email", class: "block text-sm font-medium text-slate-700 mb-1" %>
          <%= f.email_field :email, required: true, placeholder: "contoh@email.com",
                class: "block w-full rounded-lg border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-sky-500 focus:outline-none focus:ring-1 focus:ring-sky-500" %>
        </div>
        <div class="flex justify-end gap-2">
          <%= link_to "Batal", specimens_path, class: "rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50" %>
          <%= f.submit "Kirim", class: "rounded-lg bg-sky-600 px-4 py-2 text-sm font-semibold text-white hover:bg-sky-700 cursor-pointer" %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
