<div class="mx-auto max-w-5xl space-y-6 px-4 py-8 sm:px-6 lg:px-8">
  <div class="flex flex-col gap-4 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm sm:flex-row sm:items-start sm:justify-between">
    <div>
      <p class="text-sm font-medium text-sky-700"><%= t("specimens.show.label") %></p>
      <h1 class="mt-2 text-3xl font-semibold text-slate-900"><%= @specimen.order_number %></h1>
      <p class="mt-2 text-sm text-slate-600"><%= @specimen.patient_name %> • <%= specimen_summary(@specimen) %></p>
    </div>
    <div class="flex gap-2">
      <%= link_to t("specimens.actions.print_report"), print_report_specimen_path(@specimen), class: secondary_action_button_classes, target: "_blank", rel: "noopener" %>
      <%= link_to t("specimens.actions.print_labels"), barcode_labels_specimen_path(@specimen), class: secondary_action_button_classes, target: "_blank", rel: "noopener" %>
      <%= link_to t("specimens.show.back"), specimens_path, class: secondary_action_button_classes %>
    </div>
  </div>

  <div class="grid gap-6 lg:grid-cols-2">
    <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <h2 class="text-lg font-semibold text-slate-900"><%= t("specimens.show.patient_section") %></h2>
      <dl class="mt-4 space-y-3 text-sm text-slate-700">
        <div class="flex justify-between gap-4"><dt class="font-medium"><%= t("specimens.show.fields.patient_id") %></dt><dd><%= @specimen.patient_id %></dd></div>
        <div class="flex justify-between gap-4"><dt class="font-medium"><%= t("specimens.show.fields.medical_record") %></dt><dd><%= @specimen.medical_record_id %></dd></div>
        <div class="flex justify-between gap-4"><dt class="font-medium"><%= t("specimens.show.fields.birth_date") %></dt><dd><%= @specimen.birth_date %></dd></div>
        <div class="flex justify-between gap-4"><dt class="font-medium"><%= t("specimens.show.fields.gender") %></dt><dd><%= @specimen.gender %></dd></div>
        <div class="flex justify-between gap-4"><dt class="font-medium"><%= t("specimens.show.fields.referring_doctor") %></dt><dd><%= @specimen.referring_doctor.presence || "-" %></dd></div>
        <div class="flex justify-between gap-4"><dt class="font-medium"><%= t("specimens.show.fields.affiliation") %></dt><dd><%= @specimen.affiliation.presence || "-" %></dd></div>
        <div class="flex justify-between gap-4"><dt class="font-medium"><%= t("specimens.show.fields.responsible_doctor") %></dt><dd><%= @specimen.responsible_doctor.presence || "-" %></dd></div>
        <% if @specimen.patient_address.present? %>
          <div class="flex justify-between gap-4"><dt class="font-medium"><%= t("specimens.show.fields.patient_address") %></dt><dd><%= @specimen.patient_address %></dd></div>
        <% end %>
      </dl>
    </section>

    <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <h2 class="text-lg font-semibold text-slate-900"><%= t("specimens.show.collection_section") %></h2>
      <dl class="mt-4 space-y-3 text-sm text-slate-700">
        <div class="flex justify-between gap-4"><dt class="font-medium"><%= t("specimens.show.fields.lab_id") %></dt><dd><%= @specimen.lab_id %></dd></div>
        <div class="flex justify-between gap-4"><dt class="font-medium"><%= t("specimens.show.fields.department") %></dt><dd><%= @specimen.department %></dd></div>
        <div class="flex justify-between gap-4"><dt class="font-medium"><%= t("specimens.show.fields.collected_at") %></dt><dd><%= @specimen.collection_datetime ? l(@specimen.collection_datetime, format: :short) : "-" %></dd></div>
        <div class="flex justify-between gap-4"><dt class="font-medium"><%= t("specimens.show.fields.dianognes") %></dt><dd><%= @specimen.dianognes.presence || "-" %></dd></div>
        <div class="flex justify-between gap-4"><dt class="font-medium"><%= t("specimens.show.fields.status") %></dt><dd><span class="rounded-full px-3 py-1 text-xs font-semibold <%= specimen_status_classes(@specimen.status) %>"><%= t("specimens.status.#{@specimen.status}") %></span></dd></div>
      </dl>
    </section>
  </div>

  <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
    <h2 class="text-lg font-semibold text-slate-900"><%= t("specimens.show.works_section") %></h2>
    <div class="mt-4 overflow-x-auto">
      <table class="min-w-full divide-y divide-slate-200 text-sm">
        <thead class="bg-slate-50">
          <tr>
            <% %w[barcode_id patient examination status created_at actions].each do |col| %>
              <th class="px-4 py-3 text-left font-semibold text-slate-700"><%= t("specimens.show.works_table.#{col}") %></th>
            <% end %>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% @works.each do |work| %>
            <tr>
              <td class="px-4 py-4 font-medium text-slate-900"><%= link_to work.barcode_id, work_path(work), class: "hover:text-sky-700" %></td>
              <td class="px-4 py-4 text-slate-700">
                <div class="font-medium text-slate-900"><%= work.specimen.patient_name %></div>
                <div class="text-xs text-slate-500"><%= work.specimen.patient_id %> • <%= work.specimen.medical_record_id %></div>
              </td>
              <td class="px-4 py-4 text-slate-700"><%= work.examination.category %> • <%= work.examination.name %></td>
              <td class="px-4 py-4"><span class="rounded-full px-3 py-1 text-xs font-semibold <%= work_status_classes(work.status) %>"><%= t("works.status.#{work.status}") %></span></td>
              <td class="px-4 py-4 text-slate-500"><%= l(work.created_at, format: :short) %></td>
              <td class="px-4 py-3">
                <%= work_table_actions(work) %>
              </td>
            </tr>
          <% end %>
          <% if @works.empty? %>
            <tr>
              <td colspan="6" class="px-4 py-8 text-center text-sm text-slate-500"><%= t("specimens.show.works_empty") %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
</div>
