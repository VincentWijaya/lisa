<div class="mx-auto max-w-6xl space-y-6 px-4 py-8 sm:px-6 lg:px-8">

  <div>
    <%= link_to specimens_path, class: "inline-flex items-center gap-2 rounded-md border border-sky-700 px-3 py-1.5 text-sm font-semibold text-sky-700 hover:bg-sky-50" do %>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="19" y1="12" x2="5" y2="12"/>
        <polyline points="12 19 5 12 12 5"/>
      </svg>
      <%= t("specimens.show.back") %>
    <% end %>
  </div>

  <div class="flex flex-col gap-1">
    <h1 class="text-2xl font-semibold text-slate-800 leading-8"><%= t("specimens.new.title") %></h1>
    <nav aria-label="Breadcrumb" class="flex items-center gap-1 text-sm text-slate-500">
      <span class="text-slate-500"><%= t("specimens.new.breadcrumb.specimens") %></span>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="9 18 15 12 9 6"/>
      </svg>
      <span class="font-medium text-sky-700"><%= t("specimens.new.breadcrumb.current") %></span>
    </nav>
  </div>

  <%= form_with model: @specimen, url: specimens_path, scope: :specimen, method: :post, local: true, class: "space-y-6" do |f| %>
    <% if @specimen.errors.any? %>
      <div class="rounded-2xl border border-rose-200 bg-rose-50 p-4 text-sm text-rose-800">
        <p class="font-semibold"><%= t("specimens.new.errors.title") %></p>
        <ul class="mt-2 list-disc pl-5">
          <% @specimen.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <section class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
      <div class="flex items-center gap-2.5">
        <span class="block h-6 w-[3px] bg-sky-700" aria-hidden="true"></span>
        <h2 class="text-xl font-semibold text-slate-800"><%= t("specimens.new.patient_section") %></h2>
      </div>
      <div class="mt-3 border-b border-sky-700"></div>

      <div class="mt-5 space-y-5">
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <%= f.label :patient_id, t("specimens.new.fields.patient_id"), class: "block text-base font-medium text-slate-800 mb-2" %>
            <%= f.text_field :patient_id,
                required: true,
                placeholder: t("specimens.new.placeholders.patient_id"),
                class: "block w-full rounded-lg border border-slate-300 px-3 py-2.5 text-base text-slate-900 placeholder:text-slate-400 shadow-sm focus:border-sky-500 focus:outline-none focus:ring-1 focus:ring-sky-500" %>
          </div>
          <div>
            <%= f.label :patient_name, t("specimens.new.fields.patient_name"), class: "block text-base font-medium text-slate-800 mb-2" %>
            <%= f.text_field :patient_name,
                required: true,
                placeholder: t("specimens.new.placeholders.patient_name"),
                class: "block w-full rounded-lg border border-slate-300 px-3 py-2.5 text-base text-slate-900 placeholder:text-slate-400 shadow-sm focus:border-sky-500 focus:outline-none focus:ring-1 focus:ring-sky-500" %>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          <div>
            <%= f.label :medical_record_id, t("specimens.new.fields.medical_record_id"), class: "block text-base font-medium text-slate-800 mb-2" %>
            <%= f.text_field :medical_record_id,
                placeholder: t("specimens.new.placeholders.medical_record_id"),
                class: "block w-full rounded-lg border border-slate-300 px-3 py-2.5 text-base text-slate-900 placeholder:text-slate-400 shadow-sm focus:border-sky-500 focus:outline-none focus:ring-1 focus:ring-sky-500" %>
          </div>
          <div>
            <%= f.label :birth_date, t("specimens.new.fields.birth_date"), class: "block text-base font-medium text-slate-800 mb-2" %>
            <%= f.date_field :birth_date,
                required: true,
                placeholder: t("specimens.new.placeholders.birth_date"),
                class: "block w-full rounded-lg border border-slate-300 px-3 py-2.5 text-base text-slate-900 placeholder:text-slate-400 shadow-sm focus:border-sky-500 focus:outline-none focus:ring-1 focus:ring-sky-500" %>
          </div>
          <div>
            <%= f.label :gender, t("specimens.new.fields.gender"), class: "block text-base font-medium text-slate-800 mb-2" %>
            <%= f.select :gender,
                options_for_select(
                  [
                    [t("specimens.new.gender.male"),   "Laki-laki"],
                    [t("specimens.new.gender.female"), "Perempuan"]
                  ],
                  @specimen.gender
                ),
                { include_blank: t("specimens.new.placeholders.gender") },
                class: "block w-full rounded-lg border border-slate-300 px-3 py-2.5 text-base text-slate-900 shadow-sm focus:border-sky-500 focus:outline-none focus:ring-1 focus:ring-sky-500" %>
          </div>
        </div>

        <div>
          <%= f.label :patient_address, t("specimens.new.fields.patient_address"), class: "block text-base font-medium text-slate-800 mb-2" %>
          <%= f.text_area :patient_address,
              rows: 4,
              placeholder: t("specimens.new.placeholders.patient_address"),
              class: "block w-full rounded-lg border border-slate-300 px-3 py-2.5 text-base text-slate-900 placeholder:text-slate-400 shadow-sm focus:border-sky-500 focus:outline-none focus:ring-1 focus:ring-sky-500" %>
        </div>
      </div>
    </section>

    <section class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
      <div class="flex items-center gap-2.5">
        <span class="block h-6 w-[3px] bg-sky-700" aria-hidden="true"></span>
        <h2 class="text-xl font-semibold text-slate-800"><%= t("specimens.new.collection_section") %></h2>
      </div>
      <div class="mt-3 border-b border-sky-700"></div>

      <div class="mt-5 space-y-5">
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <%= f.label :department, t("specimens.new.fields.department"), class: "block text-base font-medium text-slate-800 mb-2" %>
            <%= f.text_field :department,
                placeholder: t("specimens.new.placeholders.department"),
                class: "block w-full rounded-lg border border-slate-300 px-3 py-2.5 text-base text-slate-900 placeholder:text-slate-400 shadow-sm focus:border-sky-500 focus:outline-none focus:ring-1 focus:ring-sky-500" %>
          </div>
          <div>
            <%= f.label :collection_datetime, t("specimens.new.fields.collection_datetime"), class: "block text-base font-medium text-slate-800 mb-2" %>
            <%= f.datetime_local_field :collection_datetime,
                value: @specimen.collection_datetime&.strftime("%Y-%m-%dT%H:%M"),
                class: "block w-full rounded-lg border border-slate-300 px-3 py-2.5 text-base text-slate-900 shadow-sm focus:border-sky-500 focus:outline-none focus:ring-1 focus:ring-sky-500" %>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <%= f.label :referring_doctor, t("specimens.new.fields.referring_doctor"), class: "block text-base font-medium text-slate-800 mb-2" %>
            <%= f.text_field :referring_doctor,
                placeholder: t("specimens.new.placeholders.referring_doctor"),
                class: "block w-full rounded-lg border border-slate-300 px-3 py-2.5 text-base text-slate-900 placeholder:text-slate-400 shadow-sm focus:border-sky-500 focus:outline-none focus:ring-1 focus:ring-sky-500" %>
          </div>
          <div>
            <%= f.label :responsible_doctor, t("specimens.new.fields.responsible_doctor"), class: "block text-base font-medium text-slate-800 mb-2" %>
            <%= f.text_field :responsible_doctor,
                placeholder: t("specimens.new.placeholders.responsible_doctor"),
                class: "block w-full rounded-lg border border-slate-300 px-3 py-2.5 text-base text-slate-900 placeholder:text-slate-400 shadow-sm focus:border-sky-500 focus:outline-none focus:ring-1 focus:ring-sky-500" %>
          </div>
        </div>

        <div>
          <%= f.label :dianognes, t("specimens.new.fields.dianognes"), class: "block text-base font-medium text-slate-800 mb-2" %>
          <%= f.text_area :dianognes,
              rows: 4,
              placeholder: t("specimens.new.placeholders.dianognes"),
              class: "block w-full rounded-lg border border-slate-300 px-3 py-2.5 text-base text-slate-900 placeholder:text-slate-400 shadow-sm focus:border-sky-500 focus:outline-none focus:ring-1 focus:ring-sky-500" %>
        </div>
      </div>
    </section>

    <section class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm" data-controller="examination-picker">
      <div class="flex items-center gap-2.5">
        <span class="block h-6 w-[3px] bg-sky-700" aria-hidden="true"></span>
        <h2 class="text-xl font-semibold text-slate-800"><%= t("specimens.new.works_section") %></h2>
      </div>
      <div class="mt-3 border-b border-sky-700"></div>

      <p class="mt-4 text-sm text-slate-700"><%= t("specimens.new.works_help") %></p>

      <div class="mt-4 grid gap-4 sm:grid-cols-2">
        <div>
          <label class="block text-base font-medium text-slate-800 mb-2" for="examination-search"><%= t("specimens.new.search") %></label>
          <div class="relative">
            <input type="search"
                   id="examination-search"
                   data-action="input->examination-picker#filter"
                   data-examination-picker-target="input"
                   class="block w-full rounded-lg border border-slate-300 px-3 py-2.5 pr-10 text-base text-slate-900 placeholder:text-slate-400 shadow-sm focus:border-sky-500 focus:outline-none focus:ring-1 focus:ring-sky-500"
                   placeholder="<%= t("specimens.new.search_placeholder") %>"
                   autocomplete="off">
            <span class="pointer-events-none absolute inset-y-0 right-3 flex items-center text-slate-400">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="11" cy="11" r="7"/>
                <line x1="20" y1="20" x2="16.65" y2="16.65"/>
              </svg>
            </span>
          </div>
        </div>
        <div>
          <label class="block text-base font-medium text-slate-800 mb-2" for="examination-category-filter"><%= t("specimens.new.filter_category") %></label>
          <div class="relative">
            <select id="examination-category-filter"
                    data-action="change->examination-picker#filterCategory"
                    data-examination-picker-target="category"
                    class="block w-full appearance-none rounded-lg border border-slate-300 px-3 py-2.5 pr-10 text-base text-slate-900 shadow-sm focus:border-sky-500 focus:outline-none focus:ring-1 focus:ring-sky-500">
              <option value=""><%= t("specimens.new.filter_category_all") %></option>
              <% @examination_groups.keys.compact.each do |category| %>
                <option value="<%= category %>"><%= category %></option>
              <% end %>
            </select>
            <span class="pointer-events-none absolute inset-y-0 right-3 flex items-center text-slate-700">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="6 9 12 15 18 9"/>
              </svg>
            </span>
          </div>
        </div>
      </div>

      <label class="mt-4 inline-flex cursor-pointer items-center gap-2.5 rounded-lg p-2.5">
        <input type="checkbox"
               data-action="change->examination-picker#toggleLabelGroups"
               class="size-5 rounded border-slate-400 text-sky-600 focus:ring-sky-500">
        <span class="text-base text-slate-900"><%= t("specimens.new.select_label_groups") %></span>
      </label>

      <div class="mt-4 max-h-[28rem] space-y-6 overflow-y-auto pr-1" data-examination-picker-target="list">
        <% @examination_groups.each do |category, examinations| %>
          <fieldset class="rounded-xl border border-slate-200 p-4" data-examination-category="<%= category %>">
            <legend class="px-2 text-lg font-bold text-slate-800"><%= category.presence || t("specimens.new.uncategorized") %></legend>

            <label class="mt-3 inline-flex cursor-pointer items-center gap-2.5 rounded-lg p-2.5">
              <input type="checkbox"
                     data-action="change->examination-picker#toggleCategory"
                     data-examination-picker-target="categorySelectAll"
                     data-category-key="<%= category %>"
                     class="size-5 rounded border-slate-400 text-sky-600 focus:ring-sky-500">
              <span class="text-base text-slate-900"><%= t("specimens.new.select_all") %></span>
            </label>

          <div class="mt-2 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            <% examinations.each do |exam| %>
              <% in_group = exam.label_group.present? %>
              
              <label class="flex items-start gap-3 rounded-xl p-3 hover:bg-slate-50 border border-transparent hover:border-sky-300 cursor-pointer select-none"
                    data-examination-name="<%= "#{exam.code} #{exam.name}".downcase %>"
                    data-examination-category="<%= category %>"
                    data-examination-label-group="<%= exam.label_group.to_s.downcase %>"
                    data-examination-picker-target="row">
                
                <%# Checkbox Section %>
                <%= check_box_tag "specimen[examination_ids][]",
                    exam.id,
                    false,
                    id: "exam_#{exam.id}",
                    data: {
                      action: "change->examination-picker#sync",
                      examination_picker_target: "checkbox",
                      label_group: exam.label_group.to_s.downcase,
                      category_key: category
                    },
                    class: "size-5 mt-0.5 rounded border-slate-400 text-teal-600 focus:ring-teal-500 shrink-0" %>

                <%# Content Column %>
                <div class="flex flex-col gap-1.5 font-['Poppins']">
                  <%# Title %>
                  <span class="text-base font-bold text-slate-900 leading-tight"><%= exam.name %></span>

                  <%# Metadata Sub-lists %>
                  <div class="text-sm text-slate-500 font-normal space-y-1">
                    <%# Row 1: Code and Group %>
                    <div class="flex flex-wrap items-center gap-x-2 gap-y-1">
                      <span class="inline-flex items-center gap-1.5">
                        <span class="text-slate-400">•</span><%= exam.code %>
                      </span>
                      <% if in_group %>
                        <span class="inline-flex items-center gap-1.5">
                          <span class="text-slate-400">•</span><%= exam.label_group %>
                        </span>
                      <% end %>
                    </div>

                    <%# Row 2: Specimen Type (New Line) %>
                    <% if exam.specimen_type.present? %>
                      <div class="flex items-center gap-1.5">
                        <span class="text-slate-400">•</span><%= exam.specimen_type %>
                      </div>
                    <% end %>
                  </div>
                </div>

              </label>
            <% end %>
          </div>
          </fieldset>
        <% end %>
      </div>

      <p class="mt-3 text-xs text-slate-500"
         data-examination-picker-target="summary"
         data-summary-selection-empty="<%= t("specimens.new.selection_empty") %>"
         data-summary-selection-count="<%= t("specimens.new.selection_count") %>"
         data-summary-selection-groups="<%= t("specimens.new.selection_groups") %>">
        <%= t("specimens.new.selection_empty") %>
      </p>
    </section>

    <section class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
      <div class="flex items-center gap-2.5">
        <span class="block h-6 w-[3px] bg-sky-700" aria-hidden="true"></span>
        <h2 class="text-xl font-semibold text-slate-800"><%= t("specimens.new.options_section") %></h2>
      </div>
      <div class="mt-3 border-b border-sky-700"></div>

      <label class="mt-4 flex cursor-pointer items-start gap-3 rounded-lg p-2.5">
        <%= f.check_box :manual_input, { class: "mt-1 size-5 rounded border-slate-400 text-sky-600 focus:ring-sky-500" }, "1", "0" %>
        <span>
          <span class="block text-base font-bold text-slate-900"><%= t("specimens.new.fields.manual_input") %></span>
          <span class="block text-sm text-slate-500"><%= t("specimens.new.manual_input_help") %></span>
        </span>
      </label>
    </section>

    <div class="flex flex-col-reverse gap-3 sm:flex-row sm:justify-end sm:items-center">
      <%= link_to t("specimens.new.cancel"),
          specimens_path,
          class: "inline-flex items-center justify-center rounded-lg border border-sky-700 bg-white px-5 py-2.5 text-base font-medium text-sky-700 hover:bg-sky-50" %>
      <%= f.submit t("specimens.new.submit"),
          class: "rounded-lg bg-[#0556cf] px-5 py-2.5 text-base font-medium text-white hover:opacity-90 cursor-pointer disabled:cursor-not-allowed disabled:bg-slate-300 transition" %>
    </div>
  <% end %>
</div>
