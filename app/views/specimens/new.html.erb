<div class="mx-auto max-w-6xl space-y-6 px-4 py-8 sm:px-6 lg:px-8">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <h1 class="text-3xl font-semibold text-slate-900"><%= t("specimens.new.title") %></h1>
      <p class="mt-2 text-sm text-slate-600"><%= t("specimens.new.subtitle") %></p>
    </div>
    <%= link_to t("specimens.new.back"), specimens_path, class: secondary_action_button_classes %>
  </div>

  <%= form_with model: @specimen, url: specimens_path, scope: :specimen, method: :post, local: true, class: "space-y-6" do |f| %>
    <% if @specimen.errors.any? %>
      <div class="rounded-2xl border border-rose-200 bg-rose-50 p-4 text-sm text-rose-800">
        <p class="font-semibold"><%= t("specimens.new.errors.title") %></p>
        <ul class="mt-2 list-disc pl-5">
          <% @specimen.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <h2 class="text-lg font-semibold text-slate-900"><%= t("specimens.new.patient_section") %></h2>
      <div class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        <div>
          <%= f.label :patient_id, t("specimens.new.fields.patient_id"), class: "block text-xs font-medium text-slate-700 mb-1" %>
          <%= f.text_field :patient_id, required: true, class: text_field_classes %>
        </div>
        <div class="sm:col-span-2">
          <%= f.label :patient_name, t("specimens.new.fields.patient_name"), class: "block text-xs font-medium text-slate-700 mb-1" %>
          <%= f.text_field :patient_name, required: true, class: text_field_classes %>
        </div>
        <div>
          <%= f.label :medical_record_id, t("specimens.new.fields.medical_record_id"), class: "block text-xs font-medium text-slate-700 mb-1" %>
          <%= f.text_field :medical_record_id, class: text_field_classes %>
        </div>
        <div>
          <%= f.label :birth_date, t("specimens.new.fields.birth_date"), class: "block text-xs font-medium text-slate-700 mb-1" %>
          <%= f.date_field :birth_date, required: true, class: text_field_classes %>
        </div>
        <div>
          <%= f.label :gender, t("specimens.new.fields.gender"), class: "block text-xs font-medium text-slate-700 mb-1" %>
          <%= f.select :gender,
              options_for_select(
                [
                  [t("specimens.new.gender.male"),   "Laki-laki"],
                  [t("specimens.new.gender.female"), "Perempuan"]
                ],
                @specimen.gender
              ),
              {},
              class: text_field_classes %>
        </div>
        <div class="sm:col-span-2 lg:col-span-3">
          <%= f.label :patient_address, t("specimens.new.fields.patient_address"), class: "block text-xs font-medium text-slate-700 mb-1" %>
          <%= f.text_area :patient_address, rows: 2, class: text_field_classes %>
        </div>
      </div>
    </section>

    <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <h2 class="text-lg font-semibold text-slate-900"><%= t("specimens.new.collection_section") %></h2>
      <div class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        <div>
          <%= f.label :lab_id, t("specimens.new.fields.lab_id"), class: "block text-xs font-medium text-slate-700 mb-1" %>
          <%= f.text_field :lab_id, required: true, class: text_field_classes %>
        </div>
        <div>
          <%= f.label :department, t("specimens.new.fields.department"), class: "block text-xs font-medium text-slate-700 mb-1" %>
          <%= f.text_field :department, class: text_field_classes %>
        </div>
        <div>
          <%= f.label :collection_datetime, t("specimens.new.fields.collection_datetime"), class: "block text-xs font-medium text-slate-700 mb-1" %>
          <%= f.datetime_local_field :collection_datetime,
              value: @specimen.collection_datetime&.strftime("%Y-%m-%dT%H:%M"),
              class: text_field_classes %>
        </div>
        <div>
          <%= f.label :referring_doctor, t("specimens.new.fields.referring_doctor"), class: "block text-xs font-medium text-slate-700 mb-1" %>
          <%= f.text_field :referring_doctor, class: text_field_classes %>
        </div>
        <div>
          <%= f.label :responsible_doctor, t("specimens.new.fields.responsible_doctor"), class: "block text-xs font-medium text-slate-700 mb-1" %>
          <%= f.text_field :responsible_doctor, class: text_field_classes %>
        </div>
        <div>
          <%= f.label :dianognes, t("specimens.new.fields.dianognes"), class: "block text-xs font-medium text-slate-700 mb-1" %>
          <%= f.text_field :dianognes, class: text_field_classes %>
        </div>
      </div>
    </section>

    <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm" data-controller="examination-picker">
      <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <h2 class="text-lg font-semibold text-slate-900"><%= t("specimens.new.works_section") %></h2>
          <p class="mt-1 text-xs text-slate-500"><%= t("specimens.new.works_help") %></p>
        </div>
        <div class="flex flex-wrap items-center gap-3 text-xs text-slate-600">
          <label class="inline-flex items-center gap-2">
            <input type="checkbox"
                   data-action="change->examination-picker#toggleGroup"
                   data-examination-picker-group-param="all"
                   class="h-4 w-4 rounded border-slate-300 text-sky-600 focus:ring-sky-500">
            <span><%= t("specimens.new.select_all") %></span>
          </label>
          <label class="inline-flex items-center gap-2">
            <input type="checkbox"
                   data-action="change->examination-picker#toggleLabelGroups"
                   class="h-4 w-4 rounded border-slate-300 text-sky-600 focus:ring-sky-500">
            <span><%= t("specimens.new.select_label_groups") %></span>
          </label>
        </div>
      </div>

      <div class="mt-4 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        <div>
          <label class="block text-xs font-medium text-slate-700 mb-1" for="examination-search"><%= t("specimens.new.search") %></label>
          <input type="search"
                 id="examination-search"
                 data-action="input->examination-picker#filter"
                 data-examination-picker-target="input"
                 class="<%= text_field_classes %>"
                 placeholder="<%= t("specimens.new.search_placeholder") %>">
        </div>
        <div>
          <label class="block text-xs font-medium text-slate-700 mb-1" for="examination-category-filter"><%= t("specimens.new.filter_category") %></label>
          <select id="examination-category-filter"
                  data-action="change->examination-picker#filterCategory"
                  data-examination-picker-target="category"
                  class="<%= text_field_classes %>">
            <option value=""><%= t("specimens.new.filter_category_all") %></option>
            <% @examination_groups.keys.compact.each do |category| %>
              <option value="<%= category %>"><%= category %></option>
            <% end %>
          </select>
        </div>
      </div>

      <div class="mt-4 max-h-[28rem] space-y-4 overflow-y-auto pr-1" data-examination-picker-target="list">
        <% @examination_groups.each do |category, examinations| %>
          <fieldset class="rounded-xl border border-slate-200 p-4" data-examination-category="<%= category %>">
            <legend class="px-2 text-sm font-semibold text-slate-700"><%= category.presence || t("specimens.new.uncategorized") %></legend>
            <div class="mt-2 grid gap-2 sm:grid-cols-2">
              <% examinations.each do |exam| %>
                <% in_group = exam.label_group.present? %>
                <label class="<%= in_group ? 'examination-in-group' : 'examination-solo' %> flex items-start gap-2 rounded-lg border border-slate-200 px-3 py-2 text-xs hover:border-sky-300"
                       data-examination-name="<%= "#{exam.code} #{exam.name}".downcase %>"
                       data-examination-label-group="<%= exam.label_group.to_s.downcase %>">
                  <%= check_box_tag "specimen[examination_ids][]",
                      exam.id,
                      false,
                      id: "exam_#{exam.id}",
                      data: {
                        action: "change->examination-picker#sync",
                        examination_picker_target: "checkbox",
                        label_group: exam.label_group.to_s.downcase
                      },
                      class: "mt-0.5 h-4 w-4 rounded border-slate-300 text-sky-600 focus:ring-sky-500" %>
                  <span class="flex-1">
                    <span class="block font-semibold text-slate-900"><%= exam.name %></span>
                    <span class="block text-[11px] text-slate-500">
                      <%= exam.code %>
                      <% if in_group %>
                        • <%= t("specimens.new.label_group", group: exam.label_group) %>
                      <% end %>
                      <% if exam.specimen_type.present? %> • <%= exam.specimen_type %><% end %>
                    </span>
                  </span>
                </label>
              <% end %>
            </div>
          </fieldset>
        <% end %>
      </div>

      <p class="mt-3 text-xs text-slate-500"
         data-examination-picker-target="summary"
         data-summary-selection-empty="<%= t("specimens.new.selection_empty") %>"
         data-summary-selection-count="<%= t("specimens.new.selection_count") %>"
         data-summary-selection-groups="<%= t("specimens.new.selection_groups") %>">
        <%= t("specimens.new.selection_empty") %>
      </p>
    </section>

    <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <h2 class="text-lg font-semibold text-slate-900"><%= t("specimens.new.options_section") %></h2>
      <div class="mt-4 grid gap-3 sm:grid-cols-2">
        <label class="flex items-start gap-3 rounded-xl border border-slate-200 px-4 py-3">
          <%= f.check_box :manual_input, { class: "mt-0.5 h-4 w-4 rounded border-slate-300 text-sky-600 focus:ring-sky-500" }, "1", "0" %>
          <span>
            <span class="block text-sm font-semibold text-slate-900"><%= t("specimens.new.fields.manual_input") %></span>
            <span class="block text-xs text-slate-500"><%= t("specimens.new.manual_input_help") %></span>
          </span>
        </label>
      </div>
    </section>

    <div class="flex flex-col-reverse gap-3 sm:flex-row sm:justify-end">
      <%= link_to t("specimens.new.cancel"), specimens_path, class: secondary_action_button_classes %>
      <%= f.submit t("specimens.new.submit"), class: primary_action_button_classes %>
    </div>
  <% end %>
</div>
