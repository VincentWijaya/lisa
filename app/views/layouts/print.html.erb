<!DOCTYPE html>
<html>
  <head>
    <title>LISA Print</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <style>
      body { margin: 0; padding: 12px; font-family: Arial, sans-serif; color: #000; background: #fff; }
      .label { width: 360px; padding: 12px; border: 1px solid #000; margin-bottom: 16px; }
      .label-line { margin-bottom: 6px; }
      .barcode { text-align: center; margin: 10px 0; }
      .barcode img { width: 100%; max-width: 320px; height: auto; }
      .barcode-text { text-align: center; font-weight: 700; letter-spacing: 1px; }
      .patient-name { font-size: 1.125rem; font-weight: 700; }
      .page-break { page-break-after: always; }
      @media print {
        body { margin: 0; padding: 0; }
        .label { border: none; margin: 0; width: 100%; }
      }
    </style>
  </head>
  <body>
    <%= yield %>
  </body>
</html>
