<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Lisa" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Lisa">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-slate-50 text-slate-900">
    <% if logged_in? %>
      <nav class="lisa-navbar">
        <% nav_items = [
          { label: t("nav.dashboard"), path: root_path, active: request.path == root_path },
          { label: t("nav.specimens"), path: specimens_path, active: request.path.start_with?(specimens_path) },
          { label: t("nav.works"), path: works_path, active: request.path.start_with?(works_path) },
          { label: t("nav.bank_darah"), path: bank_darah_path, active: request.path == bank_darah_path },
          { label: t("nav.mikrobiologi"), path: mikrobiologi_path, active: request.path == mikrobiologi_path },
          { label: t("nav.patologi_anatomi"), path: patologi_anatomi_path, active: request.path == patologi_anatomi_path },
          { label: t("nav.inventori"), path: inventori_path, active: request.path == inventori_path },
          { label: t("nav.monitor_qc"), path: monitor_qc_path, active: request.path == monitor_qc_path },
          { label: t("nav.laporan"), path: laporan_path, active: request.path == laporan_path }
        ] %>
        <div class="lisa-navbar__inner">
          <%= link_to "LISA", root_path, class: "lisa-navbar__brand" %>

          <div class="lisa-navbar__links" aria-label="Primary navigation">
            <% nav_items.each do |item| %>
              <%= link_to item[:label], item[:path], class: class_names("lisa-navbar__link", "lisa-navbar__link--active": item[:active]) %>
            <% end %>
            <% if current_user&.admin? %>
              <%= link_to t("nav.admin"), admin_root_path, class: class_names("lisa-navbar__link lisa-navbar__link--admin", "lisa-navbar__link--active": request.path.start_with?(admin_root_path)) %>
            <% end %>
          </div>

          <div class="lisa-navbar__user">
            <div class="lisa-navbar__user-name">
              <%= current_user.name %>
              <span class="lisa-navbar__roles">(<%= current_user.display_roles %>)</span>
            </div>
            <%= button_to t("nav.sign_out"), session_path, method: :delete, class: "lisa-navbar__sign-out", form_class: "lisa-navbar__sign-out-form" %>
          </div>
        </div>
      </nav>
    <% end %>
    <% if notice.present? || alert.present? %>
      <div class="mx-auto max-w-7xl px-4 pt-6 sm:px-6 lg:px-8">
        <% if notice.present? %>
          <div class="rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-800"><%= notice %></div>
        <% end %>
        <% if alert.present? %>
          <div class="mt-3 rounded-xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-800"><%= alert %></div>
        <% end %>
      </div>
    <% end %>

    <main>
      <%= yield %>
    </main>
  </body>
</html>
