{
  "permissions": {
    "allow": [
      "Read(.)",
      "Edit(app/**)",
      "Edit(config/**)",
      "Edit(db/**)",
      "Edit(spec/**)",
      "Edit(test/**)",
      "Edit(Gemfile)",
      "Edit(Gemfile.lock)",
      "Edit(package.json)",
      "Edit(yarn.lock)",
      "Edit(pnpm-lock.yaml)",

      "Bash(bundle install)",
      "Bash(bundle exec rails db:migrate)",
      "Bash(bundle exec rails db:rollback)",
      "Bash(bundle exec rails db:prepare)",
      "Bash(bundle exec rails routes)",
      "Bash(bundle exec rails test)",
      "Bash(bundle exec rspec)",
      "Bash(bin/rails db:migrate)",
      "Bash(bin/rails routes)",
      "Bash(bin/rails test)",
      "Bash(rubocop)",
      "Bash(bundle exec rubocop)"
    ],
    "ask": [
      "Bash(rails db:drop*)",
      "Bash(bundle exec rails db:drop*)",
      "Bash(bin/rails db:drop*)",
      "Bash(rm -rf*)",
      "Bash(git reset*)",
      "Bash(git clean*)",
      "Bash(git push*)",
      "Bash(curl*)",
      "Bash(wget*)"
    ]
  }
}